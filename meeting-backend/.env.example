APP_NAME="Red Renote Meeting Backend"
DEBUG=false

# Supabase Postgres connection. Prefer Supabase pooled/direct DB URL for backend services.
DATABASE_URL=postgresql://postgres:password@db:5432/postgres

# Redis/Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# Service URLs
STT_SERVICE_URL=http://localhost:8000
STT_API_KEY=

# API security for frontend/backend calls. Leave empty only during local development.
INTERNAL_API_KEY=
CORS_ORIGINS=["*"]

# LLM provider. If GEMINI_API_KEY is empty, service falls back to basic deterministic summaries.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash-lite
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_TIMEOUT_SECONDS=120
LLM_MAX_INPUT_CHARS=120000
LLM_RATE_LIMIT_PER_MINUTE=12
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=1
LLM_RETRY_MAX_SECONDS=12
LLM_CACHE_TTL_SECONDS=86400
